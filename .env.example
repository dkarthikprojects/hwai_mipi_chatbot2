# ─────────────────────────────────────────────────────────────────────────────
# MIPI POWER HOUSE — Environment Variables
# Copy this file to .env.local for local development (never commit .env.local)
# Set these in Vercel Dashboard → Project → Settings → Environment Variables
# ─────────────────────────────────────────────────────────────────────────────

# Anthropic API key — required for the AI chatbot (Client Queries + HWAI Copilot)
# Get yours at: https://console.anthropic.com/
VITE_ANTHROPIC_API_KEY=your_anthropic_api_key_here

# App environment
VITE_APP_ENV=production

# Optional: Backend API base URL (for when you wire Express backend)
# VITE_API_BASE_URL=https://your-backend.vercel.app
